# ── Copie ce fichier en `.env` et remplis les valeurs. Le `.env` n'est JAMAIS commité. ──

# Routes Kong (API OpenAI-compatible, pas de clé Google nécessaire)
KONG_CHAT_URL=https://REMPLACER/ai-api/v1/chat/gemini
KONG_EMBED_URL=https://REMPLACER/ai-api/v1/embeddings
# Laisser "dummy" si Kong n'exige pas de clé d'authentification
KONG_API_KEY=dummy

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX=agentic4api
# Host direct (recommandé) : console Pinecone → ton index → "Host"
PINECONE_HOST=https://agentic4api-xxxx.svc.aped-xxxx.pinecone.io

# Google Sheet (sortie du batch)
SHEET_ID=
SHEET_WORKSHEET=          # obligatoire — nom de l'onglet cible (ex: run_gemini35flash)

# Auth Google Sheets — décommenter UN seul bloc selon le contexte :
#
# ── Mode PERSO / local (défaut) — OAuth2 ──────────────────────────────────────
# Ouvre le navigateur une fois pour autoriser, sauvegarde token.json ensuite.
# Prérequis : télécharger credentials.json depuis GCP Console (OAuth2 Desktop app).
GOOGLE_AUTH_MODE=oauth2
GOOGLE_CREDENTIALS_JSON=./credentials.json
#
# ── Mode ENTREPRISE / prod — Service account ──────────────────────────────────
# GOOGLE_AUTH_MODE=service_account
# LOCAL      : GOOGLE_SA_JSON=./service_account.json
# CLOUD RUN  : GOOGLE_SA_JSON={"type":"service_account",...}  (JSON brut via Secret Manager)
# GOOGLE_SA_JSON=./service_account.json

# ── Hyperparamètres (optionnels, valeurs par défaut dans settings.py) ──
# Nom du modèle tel que renvoyé par Kong dans le champ "model" de la réponse JSON
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Retrieval
TOP_K=20                  # N8N utilisait 20 — augmenter améliore le rappel
# "rag"     : Pinecone appelé UNE fois (déterministe, rapide)
# "agentic" : le LLM décide quand appeler Pinecone (fidèle N8N, plus de tokens)
RETRIEVAL_MODE=agentic

# Génération
MAX_OUTPUT_TOKENS=4096
MAX_RETRIES=5             # N8N utilisait MAX_RETRY = 5

# Batch
BATCH_WAIT_S=2.0          # pause entre chaque question (rate limiting, identique au Wait N8N)

# Outil d'appel Pinecone
TOOL_MODE=text        # defaut — compatible Kong, pas de thought_signature
# TOOL_MODE=bind_tools  # a activer quand Kong transmet la thought_signature
